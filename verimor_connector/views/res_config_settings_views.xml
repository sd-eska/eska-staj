<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ┌─────────────────────────────────────────────────────────────────┐ -->
        <!-- │  Verimor section in General Settings                           │ -->
        <!-- └─────────────────────────────────────────────────────────────────┘ -->

        <record id="res_config_settings_view_form_verimor" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.verimor</field>
            <field name="model">res.config.settings</field>
            <field name="priority">100</field>
            <field name="inherit_id" ref="base_setup.action_general_configuration"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('app_settings_block')]" position="before">
                    <div class="app_settings_block" data-string="Verimor Connector" id="verimor_connector_settings"
                         string="Verimor Connector"
                         data-module="verimor_connector">

                        <!-- SMS credentials -->
                        <h2>Verimor SMS Gateway</h2>
                        <div class="row mt16 o_settings_container" id="verimor_sms_settings">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="verimor_sms_username" string="SMS Username"/>
                                    <div class="text-muted">
                                        Verimor account username (e.g. 908501234567)
                                    </div>
                                    <div class="content-group mt8">
                                        <field name="verimor_sms_username"
                                               id="verimor_sms_username"
                                               placeholder="908501234567"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="verimor_sms_password" string="SMS Password"/>
                                    <div class="text-muted">
                                        Verimor account password
                                    </div>
                                    <div class="content-group mt8">
                                        <field name="verimor_sms_password"
                                               id="verimor_sms_password"
                                               password="True"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="verimor_sms_source_addr" string="Sender ID (Başlık)"/>
                                    <div class="text-muted">
                                        Approved sender name registered on Verimor OIM panel
                                    </div>
                                    <div class="content-group mt8">
                                        <field name="verimor_sms_source_addr"
                                               id="verimor_sms_source_addr"
                                               placeholder="FIRMAADI"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- PBX credentials -->
                        <h2 class="mt32">Bulutsantralim PBX</h2>
                        <div class="row mt16 o_settings_container" id="verimor_pbx_settings">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="verimor_pbx_api_key" string="Bulutsantralim API Key"/>
                                    <div class="text-muted">
                                        API key from the Bulutsantralim management panel
                                    </div>
                                    <div class="content-group mt8">
                                        <field name="verimor_pbx_api_key"
                                               id="verimor_pbx_api_key"
                                               password="True"
                                               placeholder="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="verimor_pbx_extension" string="Default Extension"/>
                                    <div class="text-muted">
                                        Extension/DID to dial from for click-to-call (e.g. 1001)
                                    </div>
                                    <div class="content-group mt8">
                                        <field name="verimor_pbx_extension"
                                               id="verimor_pbx_extension"
                                               placeholder="1001"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
