<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- res.partner form – click-to-call button -->
        <record id="view_partner_form_iys_pbx" model="ir.ui.view">
            <field name="name">res.partner.form.iys.pbx</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">

                <!-- Click-to-call button next to the mobile field -->
                <xpath expr="//field[@name='mobile']" position="after">
                    <button name="action_iys_click_to_call"
                            type="object"
                            class="btn btn-sm btn-secondary"
                            string="📞 Call"
                            title="Click-to-call via Bulutsantralim"
                            icon="fa-phone"
                            invisible="not mobile"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
