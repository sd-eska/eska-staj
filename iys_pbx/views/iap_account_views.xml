<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- IAP Account form – IYS PBX credentials section -->
        <record id="view_iap_account_form_iys_pbx" model="ir.ui.view">
            <field name="name">iap.account.form.iys.pbx</field>
            <field name="model">iap.account</field>
            <field name="inherit_id" ref="iap.iap_account_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <group string="Bulutsantralim PBX Credentials"
                           invisible="provider != 'iys_pbx'">
                        <field name="pbx_api_key" password="True"
                               placeholder="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"/>
                        <field name="pbx_extension" placeholder="1001"/>
                    </group>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
