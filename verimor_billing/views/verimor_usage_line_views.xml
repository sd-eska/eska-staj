<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- List view -->
        <record id="view_verimor_usage_line_list" model="ir.ui.view">
            <field name="name">verimor.usage.line.list</field>
            <field name="model">verimor.usage.line</field>
            <field name="arch" type="xml">
                <list string="Usage Lines"
                      decoration-success="invoiced == True"
                      decoration-muted="invoiced == False">
                    <field name="event_date"/>
                    <field name="usage_type"/>
                    <field name="partner_id"/>
                    <field name="quantity"/>
                    <field name="unit_price"/>
                    <field name="amount" sum="Total"/>
                    <field name="currency_id" optional="hide"/>
                    <field name="invoiced"/>
                    <field name="reference" optional="hide"/>
                    <field name="description" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_verimor_usage_line_form" model="ir.ui.view">
            <field name="name">verimor.usage.line.form</field>
            <field name="model">verimor.usage.line</field>
            <field name="arch" type="xml">
                <form string="Usage Line">
                    <sheet>
                        <group>
                            <group string="Event">
                                <field name="usage_type"/>
                                <field name="event_date"/>
                                <field name="partner_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="reference"/>
                                <field name="description"/>
                            </group>
                            <group string="Billing">
                                <field name="quantity"/>
                                <field name="unit_price"/>
                                <field name="amount"/>
                                <field name="currency_id"/>
                                <field name="invoiced"/>
                                <field name="invoice_line_id" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search view -->
        <record id="view_verimor_usage_line_search" model="ir.ui.view">
            <field name="name">verimor.usage.line.search</field>
            <field name="model">verimor.usage.line</field>
            <field name="arch" type="xml">
                <search string="Search Usage">
                    <field name="partner_id"/>
                    <field name="usage_type"/>
                    <filter name="uninvoiced" string="Uninvoiced"
                            domain="[('invoiced','=',False)]"/>
                    <filter name="invoiced" string="Invoiced"
                            domain="[('invoiced','=',True)]"/>
                    <filter name="sms" string="SMS"
                            domain="[('usage_type','=','sms')]"/>
                    <filter name="call" string="VoIP Calls"
                            domain="[('usage_type','=','call')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_partner" string="Customer"
                                context="{'group_by': 'partner_id'}"/>
                        <filter name="group_type" string="Usage Type"
                                context="{'group_by': 'usage_type'}"/>
                        <filter name="group_month" string="Month"
                                context="{'group_by': 'event_date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Window action -->
        <record id="action_verimor_usage_line" model="ir.actions.act_window">
            <field name="name">Verimor Usage</field>
            <field name="res_model">verimor.usage.line</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_verimor_usage_line_search"/>
        </record>

        <!-- Menu -->
        <menuitem id="menu_verimor_billing_root"
                  name="Verimor Billing"
                  sequence="95"/>
        <menuitem id="menu_verimor_usage"
                  name="Usage Lines"
                  parent="menu_verimor_billing_root"
                  action="action_verimor_usage_line"
                  sequence="10"/>

    </data>
</odoo>
