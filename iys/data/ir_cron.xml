<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_iys_pull" model="ir.cron">
            <field name="name">Two-Way Sync</field>
            <field name="model_id" ref="iys.model_iys_consent"/>
            <field name="state">code</field>
            <field name="code">model._pull_from_iys()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <record id="ir_cron_iys_push_queue" model="ir.cron">
            <field name="name">Process Push Queue</field>
            <field name="model_id" ref="iys.model_iys_push_queue"/>
            <field name="state">code</field>
            <field name="code">model._process_queue()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>
