<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- IAP Account form – IYS SMS Verimor credentials section -->
        <record id="view_iap_account_form_iys_sms" model="ir.ui.view">
            <field name="name">iap.account.form.iys.sms</field>
            <field name="model">iap.account</field>
            <field name="inherit_id" ref="iap.iap_account_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <group string="IYS SMS Verimor Credentials"
                           invisible="provider != 'iys_sms_verimor'">
                        <field name="sms_username" placeholder="908501234567"/>
                        <field name="sms_password" password="True"/>
                        <field name="sms_source_addr" placeholder="FIRMAADI"/>
                        <div class="mt8" invisible="provider != 'iys_sms_verimor'">
                            <button name="action_check_sms_balance"
                                    string="Check SMS Balance"
                                    type="object"
                                    class="btn btn-secondary"/>
                        </div>
                    </group>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
